import tkinter as tk

# ===== TERE WALE FUNCTION - 100% SAME - KUCH NAHI BADLA =====
def sahil_ha(): return "HELLO SAHIL"
def sahil_he(): return "HELLO SHAMIM" 
def sahil_don(): return "HELLO IKRAMUDDIN"
def sahil_king(): return "CODING KARNA SAHE HA"
def sahil_khaan(): return "COMPUTER EK OPRETIVE MASING HA OR CODING ME USE HOTA HA 😀😀🖥️"
def sahil_khan(): return "TALLY KARNA JOB KE LIYE SAHE HA ISHE JOB GALD MIL GAYADE HA😀😀"
def sahil_kingg(): return "2+2=4"

def run_app():
    choice = entry.get().lower().strip()
    if choice =="sahil": result = sahil_ha()
    elif choice =="shamim": result = sahil_he()
    elif choice == "ikramuddin": result = sahil_don()
    elif choice =="me coding karta ho": result = sahil_king()
    elif choice =="tally karna sahi ha": result = sahil_khan()
    elif choice =="computer kya hai": result = sahil_khaan()
    elif choice =="2+2=": result = sahil_kingg()       
    else: result = "sorry is kam se mere pass nahin Hai 💔💔"
    output.config(text=result)
    entry.delete(0, tk.END)

def open_app():
    splash.destroy()
    app = tk.Tk()
    app.title("Sahil GTP")
    app.geometry("350x600")
    app.configure(bg="black")  # BLACK BACKGROUND KAR DIYA
    
    tk.Label(app, text="Sahil GTP", font=("Arial", 22, "bold"), bg="black", fg="white").pack(pady=30)
    tk.Label(app, text="🙏🙏 WELCOME TO SAHIL AI 🙏🙏", font=("Arial", 10), bg="black", fg="gray").pack()
    
    global entry, output
    entry = tk.Entry(app, font=("Arial", 14), width=22, bg="#2d2d2d", fg="white", insertbackground="white", relief="flat")
    entry.pack(pady=20)
    tk.Button(app, text="PUCHHO", bg="#10a37f", fg="white", font=("Arial", 12, "bold"), command=run_app).pack(pady=10)
    output = tk.Label(app, text="", font=("Arial", 12), bg="black", fg="white", wraplength=300, justify="left")
    output.pack(pady=20, padx=20)
    app.mainloop()

# ===== LOGO WALI SCREEN - BLACK BACKGROUND + BEECH MEIN LOGO =====
splash = tk.Tk()
splash.title("Sahil GTP")
splash.geometry("400x400")
splash.configure(bg="black")  # BACKGROUND BLACK KAR DIYA BHAI

canvas = tk.Canvas(splash, width=400, height=400, bg="black", highlightthickness=0)  # BLACK
canvas.pack()

# WAHI PURANA LOGO - KUCH NAHI BADLA - SIRF BEECH MEIN KIYA
# SAFED GOL DABBA
canvas.create_oval(150, 120, 250, 220, fill="white", outline="#d9d9d9", width=2)

# BEECH MEIN PHOOL - CHATGPT JAISE 6 PATTI - SAME TO SAME
x, y = 200, 170
size = 8
canvas.create_oval(x-size*2, y-size, x, y+size, fill="#10a37f", outline="")      # LEFT
canvas.create_oval(x, y-size, x+size*2, y+size, fill="#10a37f", outline="")      # RIGHT  
canvas.create_oval(x-size, y-size*2, x+size, y, fill="#10a37f", outline="")      # TOP
canvas.create_oval(x-size, y, x+size, y+size*2, fill="#10a37f", outline="")     # BOTTOM
canvas.create_oval(x-size*1.5, y-size*1.5, x-size*0.5, y-size*0.5, fill="#1a7f64", outline="")  # TOP-LEFT
canvas.create_oval(x+size*0.5, y+size*0.5, x+size*1.5, y+size*1.5, fill="#1a7f64", outline="")  # BOTTOM-RIGHT

# LOGO KE NEECHE KALA TEXT - AB SAFED KAR DIYA KYUNKI BACKGROUND KALA HAI
canvas.create_text(200, 250, text="Sahil GTP", font=("Arial", 18, "bold"), fill="white")

# PURE CANVAS PE CLICK KARTE HI APP KHULEGI
canvas.bind("<Button-1>", lambda e: open_app())

splash.mainloop()
